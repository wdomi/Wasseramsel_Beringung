<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Bird Ring Combination Tool</title>
  <style>
    body { font-family: Arial; padding: 20px; max-width: 900px; }
    textarea { width: 100%; height: 150px; }
    button { padding: 10px 15px; margin-top: 10px; margin-right: 10px; }
    .result { margin-top: 20px; font-weight: bold; }
  </style>
</head>
<body>
  <h2>Bird Ring Combination Tool (Advanced)</h2>

  <label>Select River:</label>
  <select id="riverSelect">
    <option>Untere Spöl</option>
    <option>Obere Spöl</option>
    <option>Ova dal Fuorn</option>
    <option>Rom</option>
    <option>Trupchun</option>
  </select>

  <h3>Import CSV of ringed birds</h3>
  <input type="file" id="csvFile" accept=".csv">

  <br>
  <button onclick="loadCSV()">Load CSV</button>
  <button onclick="findBest()">Best 1</button>
  <button onclick="generateBatch()">Generate 10</button>
  <button onclick="downloadResults()">Download Results</button>

  <div class="result" id="output"></div>

  <script>
    const colors = ["yellow","white","black","red","pink","violet","green","blue"];
    let database = {};
    let lastResults = [];

    function normalize(combo) {
      return combo.replace(/\s+/g, '').toLowerCase();
    }

    function toCombo(row) {
      return normalize(`l(${row.left_top}-${row.left_bottom})r(${row.right_top}-${row.right_bottom})`);
    }

    function loadCSV() {
      const file = document.getElementById("csvFile").files[0];
      if (!file) return alert("Please select a CSV file");

      const reader = new FileReader();
      reader.onload = function(e) {
        const text = e.target.result;
        const lines = text.split("\n");
        const headers = lines[0].split(",");

        database = {};

        for (let i = 1; i < lines.length; i++) {
          const cols = lines[i].split(",");
          if (cols.length < 5) continue;

          const row = {};
          headers.forEach((h, idx) => row[h.trim()] = cols[idx]?.trim().toLowerCase());

          const river = row.river;
          if (!database[river]) database[river] = [];

          database[river].push(toCombo(row));
        }

        document.getElementById("output").textContent = "CSV loaded successfully.";
      };

      reader.readAsText(file);
    }

    function parse(combo) {
      return combo.match(/\((.*?)\)/g)
        .map(x => x.replace(/[()]/g, '').split('-')).flat();
    }

    function generateAllCombos() {
      const combos = [];

      for (let l1 of ["alu", ...colors])
        for (let l2 of colors)
          for (let r1 of colors)
            for (let r2 of colors) {

              const arr = [l1, l2, r1, r2];
              const aluCount = arr.filter(x => x === "alu").length;
              if (aluCount !== 1) continue;

              combos.push(`l(${l1}-${l2})r(${r1}-${r2})`);
            }

      return combos;
    }

    function similarity(c1, c2) {
      const a = parse(c1);
      const b = parse(c2);

      let score = 0;

      for (let i = 0; i < 4; i++) {
        if (a[i] === b[i]) score += 3;
      }

      a.forEach(color => {
        if (b.includes(color)) score += 1;
      });

      if (a[0] === b[2] && a[1] === b[3]) score += 2;
      if (a[2] === b[0] && a[3] === b[1]) score += 2;

      return score;
    }

    function findBestCombo(localUsed, allUsed, allCombos) {
      let bestCombo = null;
      let bestScore = Infinity;

      allCombos.forEach(combo => {
        if (allUsed.includes(combo)) return;

        let worst = 0;
        localUsed.forEach(existing => {
          const sim = similarity(combo, existing);
          if (sim > worst) worst = sim;
        });

        if (worst < bestScore) {
          bestScore = worst;
          bestCombo = combo;
        }
      });

      return { bestCombo, bestScore };
    }

    function findBest() {
      const river = document.getElementById("riverSelect").value.toLowerCase();
      const allUsed = Object.values(database).flat();
      const localUsed = database[river] || [];
      const allCombos = generateAllCombos();

      const { bestCombo, bestScore } = findBestCombo(localUsed, allUsed, allCombos);

      lastResults = [bestCombo];

      document.getElementById("output").textContent =
        bestCombo
          ? `BEST: ${bestCombo.toUpperCase()} | score ${bestScore}`
          : "No valid combination";
    }

    function generateBatch() {
      const river = document.getElementById("riverSelect").value.toLowerCase();
      let allUsed = Object.values(database).flat();
      let localUsed = [...(database[river] || [])];
      const allCombos = generateAllCombos();

      let results = [];

      for (let i = 0; i < 10; i++) {
        const { bestCombo } = findBestCombo(localUsed, allUsed, allCombos);
        if (!bestCombo) break;

        results.push(bestCombo);
        localUsed.push(bestCombo);
        allUsed.push(bestCombo);
      }

      lastResults = results;

      document.getElementById("output").innerHTML =
        "NEXT 10:<br>" + results.map(r => r.toUpperCase()).join("<br>");
    }

    function downloadResults() {
      if (lastResults.length === 0) return alert("No results to download");

      let csv = "combo\n";
      lastResults.forEach(r => csv += r + "\n");

      const blob = new Blob([csv], { type: 'text/csv' });
      const url = URL.createObjectURL(blob);

      const a = document.createElement('a');
      a.href = url;
      a.download = 'new_combinations.csv';
      a.click();

      URL.revokeObjectURL(url);
    }
  </script>
</body>
</html>
